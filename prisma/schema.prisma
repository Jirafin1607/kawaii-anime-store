generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  icon      String    @default("📦")
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  price       Float
  stock       Int      @default(0)
  categoryId  String
  images      String   @default("[]") // JSON array of image paths
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model GalleryItem {
  id        String   @id @default(cuid())
  title     String   @default("")
  type      String   @default("image") // "image" or "video"
  url       String
  thumbnail String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String   @default("")
  role      String   @default("user") // "user", "bot", "system"
  content   String
  customerName  String @default("")
  customerEmail String @default("")
  customerPhone String @default("")
  isForwarded  Boolean @default(false)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id              String @id @default(cuid())
  storeName       String @default("Mi Tienda Anime")
  storeDescription String @default("")
  primaryColor    String @default("#e91e8c")
  accentColor     String @default("#7c3aed")
  bgColor         String @default("#0f0a1a")
  textColor       String @default("#f8fafc")
  whatsappNumber  String @default("")
  email           String @default("")
  facebookUrl     String @default("")
  mercadoLibreUrl String @default("")
  heroImage       String @default("")
  adminPassword   String @default("admin123")
}

model Order {
  id          String   @id @default(cuid())
  customerName  String
  customerEmail String
  customerPhone String
  items       String   // JSON array of {productId, name, price, quantity}
  total       Float
  status      String   @default("pending") // "pending", "confirmed", "shipped", "delivered"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}